// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ---------------------------------------------------------------------------
// Auth & Teams
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  avatarUrl    String?
  passwordHash String
  role         Role     @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamMemberships TeamMember[]
  assignedIncidents Incident[] @relation("AssignedTo")
  createdIncidents  Incident[] @relation("CreatedBy")
  timelineEntries   TimelineEntry[]
  comments          Comment[]
  refreshTokens     RefreshToken[]

  @@index([email])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   TeamMember[]
  incidents Incident[]
  services  Service[]

  @@index([slug])
}

model TeamMember {
  id        String     @id @default(cuid())
  userId    String
  teamId    String
  teamRole  TeamRole   @default(MEMBER)
  joinedAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ---------------------------------------------------------------------------
// Incidents
// ---------------------------------------------------------------------------

model Incident {
  id          String          @id @default(cuid())
  title       String
  description String?
  severity    Severity
  status      IncidentStatus  @default(OPEN)
  teamId      String
  createdById String
  assignedToId String?
  resolvedAt  DateTime?
  slaBreachedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  team       Team  @relation(fields: [teamId], references: [id])
  createdBy  User  @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo User? @relation("AssignedTo", fields: [assignedToId], references: [id])

  services         IncidentService[]
  timeline         TimelineEntry[]
  comments         Comment[]
  logUploads       LogUpload[]
  aiAnalyses       AiAnalysis[]
  postmortem       Postmortem?
  slaPolicy        SlaPolicy?        @relation(fields: [slaPolicyId], references: [id])
  slaPolicyId      String?
  escalations      Escalation[]
  embedding        IncidentEmbedding?
  labels           IncidentLabel[]

  @@index([teamId, status])
  @@index([severity, status])
  @@index([createdAt])
  @@index([assignedToId])
}

model Service {
  id          String        @id @default(cuid())
  name        String
  slug        String
  description String?
  teamId      String
  status      ServiceStatus @default(OPERATIONAL)
  updatedAt   DateTime      @updatedAt

  team      Team              @relation(fields: [teamId], references: [id])
  incidents IncidentService[]

  @@unique([slug, teamId])
  @@index([teamId])
}

model IncidentService {
  incidentId String
  serviceId  String

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])

  @@id([incidentId, serviceId])
}

model TimelineEntry {
  id         String          @id @default(cuid())
  incidentId String
  userId     String?
  type       TimelineEntryType
  content    String
  metadata   Json?
  createdAt  DateTime        @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([incidentId, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  incidentId String
  userId     String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([incidentId, createdAt])
}

model Escalation {
  id          String           @id @default(cuid())
  incidentId  String
  reason      String
  escalatedTo String
  status      EscalationStatus @default(PENDING)
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model Label {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6B7280")

  incidents IncidentLabel[]
}

model IncidentLabel {
  incidentId String
  labelId    String

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  label    Label    @relation(fields: [labelId], references: [id])

  @@id([incidentId, labelId])
}

// ---------------------------------------------------------------------------
// SLA
// ---------------------------------------------------------------------------

model SlaPolicy {
  id                   String @id @default(cuid())
  name                 String
  responseTimeMinutes  Int
  resolutionTimeMinutes Int

  incidents Incident[]
}

// ---------------------------------------------------------------------------
// AI & RAG
// ---------------------------------------------------------------------------

model LogUpload {
  id         String   @id @default(cuid())
  incidentId String
  filename   String
  s3Key      String
  sizeBytes  Int
  mimeType   String
  uploadedAt DateTime @default(now())

  incident  Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  chunks    LogChunk[]

  @@index([incidentId])
}

model LogChunk {
  id          String                     @id @default(cuid())
  uploadId    String
  chunkIndex  Int
  content     String
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                   @default(now())

  upload LogUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
}

model AiAnalysis {
  id              String   @id @default(cuid())
  incidentId      String
  type            AiAnalysisType
  prompt          String?
  result          Json
  tokensUsed      Int?
  modelVersion    String?
  createdAt       DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, type])
}

model Postmortem {
  id           String   @id @default(cuid())
  incidentId   String   @unique
  title        String
  summary      String
  timeline     String
  rootCauses   String
  actionItems  String
  generatedBy  String   @default("ai")
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

// Stores a single embedding per incident for similarity search
model IncidentEmbedding {
  id         String                     @id @default(cuid())
  incidentId String                     @unique
  embedding  Unsupported("vector(1536)")
  updatedAt  DateTime                   @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Severity {
  SEV1 // Critical — full outage
  SEV2 // Major — degraded service
  SEV3 // Minor — partial impact
  SEV4 // Low — no customer impact
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  INVESTIGATING
  MITIGATED
  RESOLVED
}

enum ServiceStatus {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
}

enum TimelineEntryType {
  STATUS_CHANGE
  ASSIGNMENT
  COMMENT
  LOG_UPLOAD
  AI_ANALYSIS
  ESCALATION
  SLA_BREACH
  SYSTEM
}

enum AiAnalysisType {
  ROOT_CAUSE
  LOG_SUMMARY
  SIMILAR_INCIDENTS
  POSTMORTEM
}

enum EscalationStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}
